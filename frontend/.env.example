# ========================================
# Bao Bua Keo ProMax - Environment Config
# ========================================

# REQUIRED: Smart Contract Package ID
# Get this after publishing:
#   sui client publish --gas-budget 100000000
# Copy the package ID from the output
VITE_PACKAGE_ID=0xYOUR_DEPLOYED_PACKAGE_ID

# OPTIONAL: Game Timeouts (in milliseconds)
# Time for Player 2 to join the game
# VITE_JOIN_TIMEOUT_MS=120000

# Time for Player 1 to reveal their move
# VITE_REVEAL_TIMEOUT_MS=600000

# OPTIONAL: Sui Network Configuration
# RPC Endpoint
# VITE_RPC_URL=https://fullnode.testnet.sui.io:443

# Network to use (testnet or mainnet)
# VITE_NETWORK=testnet

# ========================================
# Setup Instructions:
# 1. Copy this file to .env.local
# 2. Fill in VITE_PACKAGE_ID with your deployed package
# 3. Start development: pnpm dev
# ========================================

